{
  "name": "meeting-recorder",
  "version": "1.0.7",
  "description": "本地离线会议录音转写工具",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "npx vite build && electron-builder",
    "build:vite": "tsc && vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"electron .\"",
    "electron:build": "npm run build:vite && electron-builder"
  },
  "keywords": ["electron", "meeting", "recorder", "transcription"],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.5"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.2",
    "i18next": "^23.11.0",
    "react-i18next": "^14.1.0",
    "lucide-react": "^0.400.0",
    "uuid": "^10.0.0",
    "@types/uuid": "^10.0.0"
  },
  "build": {
    "appId": "com.meetingrecorder.app",
    "productName": "MeetingRecorder",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "python/**/*",
      "resources/**/*"
    ],
    "extraResources": [
      {
        "from": "bundled-python",
        "to": "bundled-python"
      },
      {
        "from": "models",
        "to": "models"
      },
      {
        "from": "resources",
        "to": "resources"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": ["dmg"],
      "icon": "resources/icon-512.png"
    },
    "win": {
      "target": ["nsis"],
      "icon": "resources/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "asar": true
  }
}
